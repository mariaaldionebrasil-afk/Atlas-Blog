generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Author {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  bio       String
  avatar    String?
  posts     Post[]
  reviews   Review[]
  roundups  Roundup[]
  createdAt DateTime  @default(now())
}

model Category {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  posts       Post[]
  reviews     Review[]
  roundups    Roundup[]
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum SiloType {
  PILAR
  APOIO
  SATELITE
}

enum KeywordStatus {
  PENDENTE
  APROVADA
  CANIBALIZADA
  REMOVIDA
}

enum PostType {
  APOIO
  INFORMACIONAL
  COMPARACAO
}

model Keyword {
  id                  String        @id @default(uuid())
  term                String
  searchIntent        String?
  volume              Int?
  cpc                 Float?
  status              KeywordStatus @default(PENDENTE)
  cannibalizationNote String?
  silo                Silo?         @relation(fields: [siloId], references: [id])
  siloId              String?
  posts               Post[]
  reviews             Review[]
  roundups            Roundup[]
  createdAt           DateTime      @default(now())
}

model Silo {
  id       String    @id @default(uuid())
  name     String
  type     SiloType
  parent   Silo?     @relation("SiloHierarchy", fields: [parentId], references: [id])
  parentId String?
  children Silo[]    @relation("SiloHierarchy")
  keywords Keyword[]
}

model Post {
  id                        String              @id @default(uuid())
  slug                      String              @unique
  title                     String
  excerpt                   String
  content                   String
  publishedDate             DateTime?
  coverImage                String?
  status                    ContentStatus       @default(DRAFT)
  category                  Category?           @relation(fields: [categoryId], references: [id])
  categoryId                String?
  author                    Author?             @relation(fields: [authorId], references: [id])
  authorId                  String?
  keyword                   Keyword?            @relation(fields: [keywordId], references: [id])
  keywordId                 String?
  outline                   Json?
  scheduledDate             DateTime?
  socialPublications        SocialPublication[]
  postType                  PostType?
  affiliateLinkAmazon       String?
  affiliateLinkMercadoLivre String?
  comparedReviewIdA         String?
  comparedReviewIdB         String?
  comparedReviewA           Review?             @relation("ComparisonA", fields: [comparedReviewIdA], references: [id])
  comparedReviewB           Review?             @relation("ComparisonB", fields: [comparedReviewIdB], references: [id])
  searchIntentFormat        String?
  roundupId                 String?
  roundup                   Roundup?            @relation(fields: [roundupId], references: [id])
}

model Review {
  id                        String              @id @default(uuid())
  slug                      String              @unique
  productName                String
  rating                    Float?
  summary                   String
  content                   String
  pros                      String[]
  cons                      String[]
  coverImage                String?
  price                     String?
  status                    ContentStatus       @default(DRAFT)
  author                    Author?             @relation(fields: [authorId], references: [id])
  authorId                  String?
  category                  Category?           @relation(fields: [categoryId], references: [id])
  categoryId                String?
  sourceUrls                Json?
  keyword                   Keyword?            @relation(fields: [keywordId], references: [id])
  keywordId                 String?
  scheduledDate             DateTime?
  affiliateLinkAmazon       String?
  affiliateLinkMercadoLivre String?
  roundupItems              RoundupItem[]
  socialPublications        SocialPublication[]
  comparisonsAsA            Post[]              @relation("ComparisonA")
  comparisonsAsB            Post[]              @relation("ComparisonB")
  searchIntentFormat        String?
  outline                   Json?
}

model Roundup {
  id                 String              @id @default(uuid())
  slug               String              @unique
  title              String
  snippet            String
  introContent       String
  faq                Json?
  status             ContentStatus       @default(DRAFT)
  scheduledDate      DateTime?
  author             Author?             @relation(fields: [authorId], references: [id])
  authorId           String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  categoryId         String?
  items              RoundupItem[]
  createdAt          DateTime            @default(now())
  socialPublications SocialPublication[]
  posts              Post[]
  keywordId          String?
  keyword            Keyword?            @relation(fields: [keywordId], references: [id])
  searchIntentFormat String?
  outline            Json?
}

model RoundupItem {
  id        String  @id @default(uuid())
  roundup   Roundup @relation(fields: [roundupId], references: [id])
  roundupId String
  review    Review  @relation(fields: [reviewId], references: [id])
  reviewId  String
  position  Int
}

enum SocialNetwork {
  FACEBOOK
  INSTAGRAM
}

enum SocialPublicationStatus {
  SUCCESS
  FAILED
}

model MetaCredential {
  id                         String   @id @default("singleton")
  facebookUserToken          String
  facebookUserTokenExpiresAt DateTime
  facebookPageAccessToken    String
  instagramAccessToken       String
  instagramTokenExpiresAt    DateTime
  updatedAt                  DateTime @updatedAt
}

model SocialPublication {
  id           String                   @id @default(uuid())
  post         Post?                    @relation(fields: [postId], references: [id])
  postId       String?
  review       Review?                  @relation(fields: [reviewId], references: [id])
  reviewId     String?
  roundup      Roundup?                 @relation(fields: [roundupId], references: [id])
  roundupId    String?
  network      SocialNetwork
  status       SocialPublicationStatus
  externalId   String?
  errorMessage String?
  createdAt    DateTime                 @default(now())
}
